<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">

    <ContentPage.ToolbarItems>

        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked" />

    </ContentPage.ToolbarItems>

    <VerticalStackLayout>
        <!-- Layout que organiza os elementos verticalmente -->

        <SearchBar x:Name="txt_search" 
                   Placeholder="Busca de Produtos"
                   TextChanged="txt_search_TextChanged"/>

        <!-- Barra de busca para pesquisar produtos -->

        <ListView x:Name="lst_produtos">
            <!-- Lista que exibirá os produtos cadastrados -->

            <ListView.Header>

                <Grid ColumnDefinitions="*, *, *, *, *, *"> <!-- Grid cria colunas para organizar os dados -->
                    <Label Grid.Column="0" Text="ID" /> <!-- Coluna que mostra o ID do produto -->
                    <Label Grid.Column="1" Text="Descrição" /> <!-- Coluna da descrição do produto -->
                    <Label Grid.Column="2" Text="Preço" /> <!-- Coluna do preço -->
                    <Label Grid.Column="3" Text="Qnt" /> <!-- Coluna da quantidade -->
                    <Label Grid.Column="4" Text="Total" /> <!-- Coluna do valor total -->

                </Grid>
            </ListView.Header>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <ViewCell.ContextActions> <!-- Menu que aparece ao deslizar o item da lista -->

                            <MenuItem Text="Remover" Clicked="MenuItem_Clicked" /> <!-- Opção para remover o produto da lista -->

                        </ViewCell.ContextActions>

                        <Grid ColumnDefinitions="*, *, *, *, *, *">
                            <Label Grid.Column="0" Text="{Binding Id}" />
                            <Label Grid.Column="1" Text="{Binding Descricao}" />
                            <Label Grid.Column="2" Text="{Binding Preco}" />
                            <Label Grid.Column="3" Text="{Binding Quantidade}" />
                            <Label Grid.Column="4" Text="{Binding Total}" />
   
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>
    </VerticalStackLayout>
</ContentPage>