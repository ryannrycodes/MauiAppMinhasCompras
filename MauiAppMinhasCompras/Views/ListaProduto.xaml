<?xml version="1.0" encoding="utf-8" ?>

<!-- Página que mostra a lista de produtos -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">

    <!-- Itens da barra superior -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" />
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked" /> <!-- Botão que abre a tela de adicionar produto -->
    </ContentPage.ToolbarItems>
    
    <!-- Layout vertical da tela -->
    <VerticalStackLayout>
        <Label 
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
    </VerticalStackLayout>
</ContentPage>